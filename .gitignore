# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Claude Code session state — everything under .claude/ EXCEPT
# settings.json (shared project-scoped permissions for the Claude
# Code PR workflow; documented in CLAUDE.md).
# NOTE: must be `.claude/*` (with wildcard) not `.claude/` — git
# can't re-include a file under an excluded directory, but it can
# under wildcard-excluded contents.
.claude/*
!.claude/settings.json

# Build / packaging artifacts
*.zip

# Kiosk LaunchAgent log files (generated at runtime, not source)
kiosk/*.out.log
kiosk/*.err.log

# Chrome kiosk profile directories (created at runtime in $HOME)
.kiosk-app1-profile/
.kiosk-app2-profile/
