# App 3 display geometry. Read by kiosk/launch-app3-{center,left,right}.sh.
#
# ⚠ Values must be BARE INTEGERS — no quotes, no decimals, no units.
#   ✓  CENTER_X=0
#   ✗  CENTER_X="0"       (Chrome receives the quotes too and the
#                          --window-position flag silently breaks)
#   ✗  CENTER_X=0px
#   ✗  CENTER_X=0.0
#
# Defaults assume a typical 3-screen exhibition setup: three displays of
# identical resolution arranged left → center → right in System Settings →
# Displays → Arrange, with the CENTER display set as macOS's Main Display
# (drag the white menu-bar strip onto the center screen in the Arrange
# pane).
#
# Coordinates are in macOS's global display coordinate space. The Main
# Display's top-left is (0, 0); displays to the left have negative X;
# displays to the right have positive X.
#
# Edit these values to match your setup. The defaults work for three
# 1920×1080 displays arranged in a row.
#
# If your displays are different sizes / non-standard arrangement, set
# each display's X/Y to that display's top-left corner in the global
# space and DISPLAY_WIDTH/HEIGHT to ITS resolution. (DISPLAY_WIDTH/HEIGHT
# is currently a single shared value across all three; if you need
# per-display sizes the launch scripts would need a small extension —
# ask the dev team.)

DISPLAY_WIDTH=1920
DISPLAY_HEIGHT=1080

# Center display (where the controls + middle photo render).
# This MUST be the macOS Main Display, so its top-left is (0, 0).
CENTER_X=0
CENTER_Y=0

# Left display — to the left of center, so its top-left X is negative.
LEFT_X=-1920
LEFT_Y=0

# Right display — to the right of center.
RIGHT_X=1920
RIGHT_Y=0
