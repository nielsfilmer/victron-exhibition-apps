<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  LaunchAgent for App 1 kiosk — ESS content version.
  Install path: ~/Library/LaunchAgents/com.intersolar.app1-ess.plist
  Replace __PROJECT_DIR__ with the absolute path to the project root before installing.

  App 1 ships in three content versions (ESS / OL / Microgrid). Only
  ONE may be loaded at a time per CLAUDE.md. The wrapper script
  launch-app1-ess.sh calls launch-app1.sh with the version arg, which
  resolves the right config.js + media/ under
  app1-slideshow/versions/ess/.
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.intersolar.app1-ess</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__PROJECT_DIR__/kiosk/launch-app1-ess.sh</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
  </dict>

  <key>ThrottleInterval</key>
  <integer>10</integer>

  <key>StandardOutPath</key>
  <string>__PROJECT_DIR__/kiosk/app1-ess.out.log</string>

  <key>StandardErrorPath</key>
  <string>__PROJECT_DIR__/kiosk/app1-ess.err.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>
</dict>
</plist>
