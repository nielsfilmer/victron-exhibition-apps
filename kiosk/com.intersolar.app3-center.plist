<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  LaunchAgent for App 3 — CENTER (Main Display, controls + middle photo).
  Install path: ~/Library/LaunchAgents/com.intersolar.app3-center.plist
  Replace __PROJECT_DIR__ with the absolute path to the project root before installing.
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.intersolar.app3-center</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__PROJECT_DIR__/kiosk/launch-app3-center.sh</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
  </dict>

  <key>ThrottleInterval</key>
  <integer>10</integer>

  <key>StandardOutPath</key>
  <string>__PROJECT_DIR__/kiosk/app3-center.out.log</string>

  <key>StandardErrorPath</key>
  <string>__PROJECT_DIR__/kiosk/app3-center.err.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>
</dict>
</plist>
